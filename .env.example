# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Host ---
# Apex domain used by the proxy to extract tenant subdomains.
# Local dev: localhost:3000
# Production: platform.com (replace with real apex)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@fanaticcoders.com

# --- SMS / Phone OTP (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
# Fallback if no Messaging Service:
TWILIO_FROM_NUMBER=

# --- Cloudflare Turnstile ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- App-layer encryption (PII) ---
# 32-byte base64 secret for AES-GCM encryption of passport/EID/visa numbers.
ENCRYPTION_KEY=

# --- Supabase auth webhook ---
# HMAC shared secret used to verify webhooks from Supabase Auth.
SUPABASE_AUTH_WEBHOOK_SECRET=

# --- Scheduled jobs ---
# Shared secret sent as x-cron-secret to outbound queue and reconciliation cron routes.
CRON_SECRET=

# --- WhatsApp Cloud API webhook ---
# Verify token used by Meta during the GET subscription handshake.
WHATSAPP_VERIFY_TOKEN=
# Meta App Secret used to HMAC-verify inbound webhook payloads (X-Hub-Signature-256).
WHATSAPP_APP_SECRET=

# --- SMS providers (Step 20) ---
# Optional platform-level Unifonic AppSid (per-tenant config in tenant_sms_config supersedes).
UNIFONIC_APP_SID=
# Shared secret used to verify Unifonic delivery-report / inbound webhooks.
UNIFONIC_WEBHOOK_SECRET=

# --- Tap payments ---
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
TAP_WEBHOOK_SECRET=
TAP_API_BASE=https://api.tap.company

# --- Stripe subscriptions ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# --- Meetings / recordings ---
DAILY_API_KEY=
DAILY_WEBHOOK_SECRET=

# --- Document scanning ---
VIRUSTOTAL_API_KEY=

# --- AI meeting summaries ---
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# --- Observability (stub in Step 1) ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# --- Launch a11y gate (Playwright auth setup) ---
# Used by tests/auth.setup.ts to sign in once per role and write
# tests/.auth/<role>.json storage states. Missing creds skip the matching
# role's authenticated a11y spec with a warning (never fail CI).
# See docs/ops/seed-creds.md for local-dev values.
E2E_BASE_URL=http://localhost:3100
# Required by .github/workflows/public-questionnaire-smoke.yml. Must point to
# the deployed staging frontend, not localhost.
STAGING_PUBLIC_BASE_URL=
E2E_TENANT_SLUG=firm
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_PRO_EMAIL=
E2E_PRO_PASSWORD=
E2E_CUSTOMER_EMAIL=
E2E_CUSTOMER_PASSWORD=
# Employee login is phone-OTP in v1 — leave blank to skip the employee
# a11y spec with a warning (documented in docs/step-30b-launch-gate-remainder-plan.md).
E2E_EMPLOYEE_EMAIL=
E2E_EMPLOYEE_PASSWORD=

# --- Load testing (k6) ---
# Required by every load-tests/k6/*.js script. No localhost default — the
# script refuses to run without an explicit URL, and refuses any host on the
# production deny list. See docs/ops/load-testing.md.
K6_BASE_URL=http://localhost:3100
# Optional opt-in for staging hosts not covered by the default allow-list
# (localhost / *.local / *.vercel.app). Cannot override the deny list.
STAGING_HOST=
# Tenant slug consumed by pro.js / customer.js. Defaults to "firm" when unset.
TENANT_SLUG=firm
# Authenticated cookies for pro.js / customer.js — see docs/ops/load-testing.md
# for the capture procedure. Leave blank for unauthenticated smoke runs.
# WARNING: pasting cookies into the shell leaks them into shell history; prefer
# `set +o history` or sourcing from a non-history env file.
PRO_COOKIE=
CUSTOMER_COOKIE=
# Set to 1 to switch from smoke (single VU / 30 s) to full launch targets.
# Required for the published p95 / error-rate targets — see docs/ops/load-testing.md.
FULL_LOAD=
